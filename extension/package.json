{
  "name": "flux-sync",
  "displayName": "FluxSync",
  "version": "1.0.0",
  "description": "Universal Agnetic Bridge for AI CLIs",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flux-sync.reviewProposal",
        "title": "FluxSync: Review Pending Proposal"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "test": "node ./out/test/runTests.js"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^10.2.0",
    "mocha": "^11.7.5",
    "typescript": "^6.0.3"
  }
}
